# Configurações do Firebase Cloud Messaging (FCM) para o cliente Web (Vite)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=

# Configurações do Banco de Dados Supabase (Opcional - Caso queira conectar seu próprio projeto)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Chave privada da conta de serviço Firebase (FCM Admin)
# Deve ser colada como uma única linha contendo o JSON completo gerado pelo Firebase Console
FIREBASE_SERVICE_ACCOUNT=
